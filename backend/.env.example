# SnapBooth Studio Backend — Environment Variables
# Salin file ini: cp .env.example .env

# Port backend Express API
PORT=4000

# JWT Secret Key (ganti dengan string acak yang panjang saat production)
JWT_SECRET=snapbooth_secret_key_2024_change_this_in_production

# Path database SQLite (relatif dari folder backend/)
DATABASE_PATH=./src/database/snapbooth.db

# URL frontend (untuk CORS)
# Development: http://localhost:8080
# Production EC2: http://PUBLIC_IP_EC2 atau http://yourdomain.com
CLIENT_URL=http://localhost:8080

# Environment: development | production
NODE_ENV=development
